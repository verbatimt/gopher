{
  "name": "gopher-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "module": "src/index.ts",
  "engines": {
    "bun": ">=1.3.0"
  },
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "start": "bun src/index.ts",
    "typecheck": "tsc --noEmit",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check .",
    "test": "NODE_ENV=test bun test",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun run src/db/migrate.ts",
    "db:seed": "bun run src/db/seed.ts"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.4.0",
    "@elysiajs/jwt": "^1.4.0",
    "@elysiajs/openapi": "^1.4.10",
    "drizzle-orm": "^0.44.6",
    "elysia": "^1.4.10",
    "ioredis": "^5.9.0",
    "postgres": "^3.4.7",
    "rrule": "^2.8.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.4",
    "@electric-sql/pglite": "^0.5.3",
    "@types/bun": "^1.3.10",
    "drizzle-kit": "^0.31.6",
    "ioredis-mock": "^8.13.1",
    "typescript": "^5.9.3"
  }
}
