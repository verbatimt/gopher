# Gopher API — environment contract.
# Copy to `.env` and fill in real values for local development. `.env` is git-ignored.
# Do NOT put real secrets in this file; placeholders only.

# HTTP port the Elysia API listens on.
PORT=3000

# Node-style environment: development | production | test
NODE_ENV=development

# PostgreSQL connection string.
# Local (compose) network hostname is `gopher-db`; from the host use localhost if mapped.
DATABASE_URL=postgres://gopher:CHANGE_ME@gopher-db:5432/gopher

# Password for the postgres superuser/app role (consumed by the compose stack).
POSTGRES_PASSWORD=CHANGE_ME

# Redis connection string. Compose hostname is `gopher-redis`.
REDIS_URL=redis://gopher-redis:6379

# Secret used to sign JWT access tokens (HS256). Use a long random string (>=32 bytes).
JWT_SECRET=CHANGE_ME_use_a_long_random_string

# Cookie domain for the refresh-token cookie. On the LAN this is the API host or blank
# for host-only cookies. No `Secure` flag is set (plain HTTP on the trusted LAN).
COOKIE_DOMAIN=

# Comma-separated list of allowed origins for credentialed CORS (direct cross-origin
# browser access during dev). Never a wildcard. The deployed web client is same-origin
# and needs no CORS. Example: http://localhost:8080,http://gopher.local
CORS_ORIGINS=
