# Compose variable substitution for the local stack.
# Copy to `src/infra/.env` (git-ignored) and set real values. Defaults in
# docker-compose.yml let the stack start without this file (dev convenience only).

# Postgres role / database (the API connects as this user to database POSTGRES_DB).
POSTGRES_USER=gopher
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=gopher

# Secret for signing JWT access tokens (HS256). Long random string (>=32 bytes).
JWT_SECRET=CHANGE_ME_use_a_long_random_string

# Host port the API is published on (container always listens on 3000).
API_PORT=3000

# API runtime mode for the base stack.
NODE_ENV=production

# Optional: cookie domain and credentialed CORS origins (comma-separated, no wildcard).
COOKIE_DOMAIN=
CORS_ORIGINS=
